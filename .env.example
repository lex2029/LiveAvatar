# HuggingFace token (read access) for auto-downloading model checkpoints
HF_KEY=hf_your_token_here

# Supabase project credentials (job queue)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Worker API key for authenticating with the job queue
WORKER_API_KEY=your_worker_api_key_here
