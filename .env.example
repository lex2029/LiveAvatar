# HuggingFace token (read access) for auto-downloading model checkpoints
HF_KEY=hf_your_token_here

# Supabase anon key (job queue auth)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Worker API key for authenticating with the job queue
WORKER_API_KEY=your_worker_api_key_here

# (Optional) Path to pre-merged FP8 noise model for fast startup (~8s vs ~45s)
# Generate with setup.sh --merge-model or download from HuggingFace
# LIVEAVATAR_MERGED_NOISE_MODEL_DIR=ckpt/Wan2.2-S2V-14B-merged-liveavatar-prefp8-test
